#!/usr/bin/env bash

## Set functions
display_help () {
	# shellcheck disable=SC2059
	printf "${Genie} This is The Great Brewdini. He only grants one wish; he updates your Homebrew formulae and Casks.\n" \
	| fmt -w 80
	printf "Usage: brewdini [-option] [--option]\n"
	printf "Options:\n"
	printf "%-20s\t%s\n" "  -a, --all" "Include apps that auto-update in the upgrade"
	printf "%-20s\t%s\n" "  -f, --force" "Force-reinstall apps that are marked as 'latest"
	printf "%-20s\t%s\n" "  -i, --interactive" "Run updates in interactive mode"
	exit 1
}

wrong_dir () {
	# shellcheck disable=SC2059
	printf "\a${Genie} WARNING: Homebrew not found in default location: '$(brew --prefix)'\n"
	printf "This is problematic and should be corrected before checking for updates. Visit the following URL for more information:\n" \
	| fmt -w 80
	printf "https://docs.brew.sh/FAQ#why-should-i-install-Homebrew-in-the-default-location\n"
	printf "\nExiting.\n"
	exit 1
}

tap_cu () {
	printf "\a\n${Genie} WARNING: 'brew-cask-upgrade' not found, tapping now...\n"; echo
	brew tap buo/cask-upgrade
	printf "Done.\n"
}

## Set variables
Genie="\U1F9DE"		# 🧞
Args=(-q -y)

## Parse command line options
while true; do
	shopt -s nocasematch
	case "$1" in
		-a | --all )
			Args=(-a -y -q)
			shift
		;;
		-f | --force )
			Args=(-a -f -y -q)
			shift
		;;
		-i | --interactive )
			Args=(-a -f -i)
			shift
		;;
		-h | --help )
			display_help
		;;
		\?)
		;;
		"" )
			shift
			break
		;;
		* )
			echo -e "*** UNKNOWN OPTION ***"; echo
			display_help
		;;
	esac
done

## Test for Apple silicon
if [[ $(arch) == arm64 ]]; then
	if [[ $(brew --prefix) != /opt/homebrew ]]; then
		wrong_dir
	fi
else
	if [[ $(brew --prefix) != /usr/local ]]; then
		wrong_dir
	fi
fi

## Test for brew-cask-upgrade
if ! brew tap | grep cask-upgrade >/dev/null; then
	tap_cu
fi

## Check for Homebrew, Formulae, and Cask upgrades; install them all
# shellcheck disable=SC2059
printf "${Genie} Checking Homebrew & Formulae for updates...\n\n"
if [[ $(brew update) != "Already up-to-date." ]]; then
	# shellcheck disable=SC2059
	printf "\n${Genie} Upgrading Homebrew & Formulae...\n\n"
	brew upgrade
fi

# shellcheck disable=SC2059
printf "${Genie} Checking for Cask updates; upgrading & cleaning up...\n\n"
brew cu "${Args[@]}" --cleanup; echo

# shellcheck disable=SC2059
printf "${Genie} Cleaning up Formulae...\n"
brew cleanup --prune=all; echo

## If any Casks are pinned, display them
Pinned=$(brew cu pinned 2>&1)
if [[ -z ${Pinned} ]]; then
	# shellcheck disable=SC2059
	printf "${Genie} No pinned Casks found, skipping...\n\n"
else
	printf "${Genie} The following Pinned Casks were found:\n";
	brew cu pinned
fi

## Check Homebrew
printf "\n${Genie} Process complete; checking Homebrew...\n\n"
## Exit normally if OK
brew doctor \
&& echo -e "Done. $Genie" \
&& exit 0

## Exit abormally with message if not OK
# shellcheck disable=SC2059
printf "\a\n${Genie} Exiting with abnormal status; see above messaging.\n"
exit 1
